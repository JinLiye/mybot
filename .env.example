MYBOT_PROVIDER=vllm

MYBOT_VLLM_API_BASE=http://127.0.0.1:8000/v1
MYBOT_VLLM_API_KEY=EMPTY
MYBOT_VLLM_MODEL=Qwen/Qwen3-8B

MYBOT_BAILIAN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
MYBOT_BAILIAN_API_KEY=
MYBOT_BAILIAN_MODEL=qwen-plus-latest

MYBOT_SYSTEM_PROMPT=You are mybot, a pragmatic AI assistant.
MYBOT_MAX_HISTORY_MESSAGES=20
MYBOT_MAX_ITERATIONS=8
MYBOT_MAX_TOKENS=4096
